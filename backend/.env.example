# ─────────────────────────────────────────────────────────────────────────────
# Clovio Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env     (Linux/Mac)
#   copy .env.example .env   (Windows)
# ─────────────────────────────────────────────────────────────────────────────

# Which AI provider to use as PRIMARY: "groq" or "deepseek"
AI_PROVIDER="groq"

# Groq API key (required if AI_PROVIDER="groq")
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=""

# DeepSeek API key (required if AI_PROVIDER="deepseek")
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# AUTOMATIC FALLBACK
# If you set BOTH keys, the service will automatically fall back to the other
# provider when the primary one fails after all retries. No other changes needed.
#
#   AI_PROVIDER="groq"  + GROQ_API_KEY + DEEPSEEK_API_KEY  →  Groq primary, DeepSeek fallback
#   AI_PROVIDER="deepseek" + DEEPSEEK_API_KEY + GROQ_API_KEY →  DeepSeek primary, Groq fallback
#   Only one key set  →  single-provider mode, no fallback
# ─────────────────────────────────────────────────────────────────────────────
